                <div class="form-group">
                    <label class="form-label">Role Color</label>
                    <input type="color" id="roleColor" value="${role.color}" style="width:100%; height:40px; border:none; cursor:pointer;">
                </div>
                <div class="form-group">
                    <label class="form-label">Permissions</label>
                    <div class="permission-grid">
                        <div class="perm-item"><span>Administrator</span><div class="toggle-switch ${role.permissions.admin ? 'active' : ''}" onclick="this.classList.toggle('active')" id="permAdmin"></div></div>
                        <div class="perm-item"><span>Ban Members</span><div class="toggle-switch ${role.permissions.ban ? 'active' : ''}" onclick="this.classList.toggle('active')" id="permBan"></div></div>
                        <div class="perm-item"><span>Kick Members</span><div class="toggle-switch ${role.permissions.kick ? 'active' : ''}" onclick="this.classList.toggle('active')" id="permKick"></div></div>
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; margin-top:30px;">
                    <button class="btn-danger" onclick="deleteRole('${role.id}')">Delete Role</button>
                    <button class="btn-primary" onclick="saveRole('${role.id}')">Save</button>
                </div>
            `;
        }

        function saveRole(roleId) {
            const server = data.servers.find(s => s.id === data.activeServer);
            const role = server.roles.find(r => r.id === roleId);
            role.name = document.getElementById('roleName').value;
            role.color = document.getElementById('roleColor').value;
            role.permissions.admin = document.getElementById('permAdmin').classList.contains('active');
            role.permissions.ban = document.getElementById('permBan').classList.contains('active');
            role.permissions.kick = document.getElementById('permKick').classList.contains('active');
            if (role.permissions.admin) { role.permissions.ban = true; role.permissions.kick = true; }
            renderSettingsRoles();
        }

        function deleteRole(roleId) {
            const server = data.servers.find(s => s.id === data.activeServer);
            server.roles = server.roles.filter(r => r.id !== roleId);
            server.members.forEach(m => { m.roles = m.roles.filter(rId => rId !== roleId); });
            renderSettingsRoles();
        }

        // --- MEMBERS SYSTEM ---
        function renderSettingsMembers() {
            const server = data.servers.find(s => s.id === data.activeServer);
            const content = document.getElementById('settingsContent');
            content.innerHTML = `<div class="settings-title">Members</div>`;
            const list = document.createElement('div');
            list.style.marginTop = "20px";
            
            server.members.slice(0, 30).forEach(m => {
                const div = document.createElement('div');
                div.style.cssText = 'display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; padding:10px; background:var(--bg-tertiary); border-radius:4px;';
                let roleOptions = '<option value="">No Role</option>';
                server.roles.forEach(r => { roleOptions += `<option value="${r.id}" ${m.roles.includes(r.id) ? 'selected' : ''}>${r.name}</option>`; });
                div.innerHTML = `
                    <div style="display:flex; align-items:center; gap:10px;">
                        <img src="https://picsum.photos/seed/${m.avatar}/32/32" style="border-radius:50%;">
                        <span style="font-weight:600;">${m.isBot ? '<span style="color:#5865f2">[BOT]</span> ' : ''}${m.name}</span>
                    </div>
                    ${m.isBot ? '' : `<select class="form-input" style="width:auto; padding:5px; font-size:12px;" onchange="assignRole('${m.id}', this.value)">${roleOptions}</select>`}
                `;
                list.appendChild(div);
            });
            content.appendChild(list);
        }

        function assignRole(userId, roleId) {
            const server = data.servers.find(s => s.id === data.activeServer);
            const member = server.members.find(m => m.id === userId);
            if (!member) return;
            member.roles = roleId === "" ? [] : [roleId];
            if (userId === data.currentUser.id) data.currentUser.roles = member.roles;
            renderMembers();
        }

        function openCreateServerModal() { document.getElementById('createServerModal').style.display = 'flex'; }
        
        function confirmCreateServer() {
            const name = document.getElementById('newServerName').value;
            if(!name) return;
            createServer(name);
            closeModals();
            renderServers();
            switchServer(data.servers[data.servers.length-1].id);
        }

        function closeModals() { document.querySelectorAll('.modal-overlay').forEach(m => m.style.display = 'none'); }
        function scrollToBottom() { document.getElementById('mainContent').scrollTop = document.getElementById('mainContent').scrollHeight; }
        function toggleTheme() { document.body.toggleAttribute('data-theme'); }
        function addChannel() {
            const name = prompt("Enter channel name");
            if(name) {
                const server = data.servers.find(s => s.id === data.activeServer);
                server.channels.push({ id: 'c-'+Date.now(), name: name.toLowerCase().replace(' ', '-'), type: 'text', messages: [] });
                renderSidebar();
            }
        }
        
        init();
    </script>
</body>
</html>
