        function renderDmChat() {
            const user = findUserById(data.activeDm);
            if (!user) return;

            document.getElementById('chatHash').innerHTML = `<img src="https://picsum.photos/seed/${user.avatar}/32/32" style="width:32px; height:32px; border-radius:50%;">`;
