                container.innerHTML = `<div style="margin:auto; text-align:center; color:var(--text-muted)"><h2>This is the beginning of your direct message history with <strong>${user.name}</strong>.</h2></div>`;
            } else {
                messages.forEach(msg => appendMessage(msg, false, null, true)); 
            }
            scrollToBottom();
        }

        function appendMessage(msg, scroll = true, serverContext = null, isDm = false) {
            const container = document.getElementById('mainContent');
            const user = findUserById(msg.userId) || { name: 'System', avatar: 'x' };
            
            let color = 'var(--text-normal)';
            if (isDm) {
                color = msg.userId === data.currentUser.id ? 'var(--brand)' : 'var(--text-normal)';
            } else if (serverContext) {
                if (user.id === serverContext.owner) color = '#f0b232'; 
                else if (user.isBot) color = '#5865f2';
                else if (user.roles && user.roles.length > 0) {
                    const role = serverContext.roles.find(r => user.roles.includes(r.id));
                    if (role) color = role.color;
                }
            }

            const div = document.createElement('div');
            div.className = 'message-group';
            div.innerHTML = `
                <img src="https://picsum.photos/seed/${user.avatar}/40/40" class="msg-avatar" onclick="openUserPopup(event, '${user.id}')">
                <div style="flex:1">
                    <div class="msg-header">
                        <span class="msg-username" style="color:${color}" onclick="openUserPopup(event, '${user.id}')">${user.isBot ? `<span style="background:#5865f2; color:white; padding:1px 2px; border-radius:3px; font-size:10px; margin-right:4px;">BOT</span>` : ''}${user.name}</span>
                        <span class="msg-timestamp">${msg.time}</span>
                    </div>
                    <div class="msg-text">${msg.text}</div>
                </div>
            `;
            container.appendChild(div);
            if (scroll) scrollToBottom();
        }

        // --- CHAT SIMULATION (Server Only) ---
        function startChatSimulation(server) {
            const interval = setInterval(() => {
                const channel = server.channels.find(c => c.id === data.activeChannel);
                if (!channel || data.viewMode !== 'server') return;

                if (Math.random() < 0.2) {
                    generateBotMessage(server, channel, null);
                }
            }, 8000);

            data.chatTimers[server.id] = interval;
        }

        function generateBotMessage(server, channel, triggerText) {
            const candidates = server.members.filter(m => !m.isBot && m.id !== data.currentUser.id && m.status === 'online' && !m.banned);
            if (candidates.length === 0) return;
            
            const user = candidates[Math.floor(Math.random() * candidates.length)];
            let text = triggerText || slangGen();

            const msg = { userId: user.id, text: text, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
            channel.messages.push(msg);
            
            if (data.activeChannel === channel.id && data.viewMode === 'server') {
                appendMessage(msg, true, server);
            }

            if (!triggerText) checkTriggers(text, server, channel);
        }

        function slangGen() {
            const slang = ["fr fr", "no cap", "sheesh", "bruh moment", "imma head out", "that's wild", "bet", "say less", "facts", "anyone here?"];
            return slang[Math.floor(Math.random() * slang.length)];
        }

        function checkTriggers(text, server, channel) {
            const lower = text.toLowerCase();
            conversations.forEach(conv => {
                if (conv.triggers.some(t => lower.includes(t))) {
                    if (Math.random() > 0.5) {
                        const responderCount = Math.floor(Math.random() * 2) + 1;
                        const candidates = server.members.filter(m => !m.isBot && m.id !== data.currentUser.id && m.status === 'online');
                        for(let i=0; i<responderCount && i < candidates.length; i++) {
                            const responder = candidates[Math.floor(Math.random() * candidates.length)];
                            setTimeout(() => {
                                const response = conv.responses[Math.floor(Math.random() * conv.responses.length)];
                                const msg = { userId: responder.id, text: response, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
                                channel.messages.push(msg);
                                if (data.activeChannel === channel.id && data.viewMode === 'server') appendMessage(msg, true, server);
                            }, 1000 + (i*500));
                        }
                    }
                }
            });
        }

        // --- USER INPUT HANDLING ---
        document.getElementById('messageInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') handleSend();
        });

        function handleSend() {
            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            if (!text) return;

            if (data.viewMode === 'dm') {
                handleDmSend(text);
            } else if (data.viewMode === 'server') {
                handleServerSend(text);
            }
            input.value = '';
        }

        function handleServerSend(text) {
            const server = data.servers.find(s => s.id === data.activeServer);
            const channel = server.channels.find(c => c.id === data.activeChannel);
            const msg = { userId: data.currentUser.id, text: text, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
            
            channel.messages.push(msg);
            appendMessage(msg, true, server);

            if (text.startsWith('/')) {
                handleCommand(text, server, channel);
            } else {
                checkTriggers(text, server, channel);
            }
        }

        function handleDmSend(text) {
            const friendId = data.activeDm;
            if (!data.dms[friendId]) data.dms[friendId] = [];

            const msg = { userId: data.currentUser.id, text: text, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
            data.dms[friendId].push(msg);
            appendMessage(msg, true, null, true);

            handleFriendReply(friendId, text);
        }

        function handleFriendReply(friendId, text) {
            const lower = text.toLowerCase();
            let reply = "";
            
            if (lower.includes("hello") || lower.includes("yoo")) reply = "whats good";
            else if (lower.includes("wanna play a game") || lower.includes("wanna play")) reply = "bet";
            else if (lower.includes("what game")) reply = "Roblox";
            else reply = "mhm";

            setTimeout(() => {
                const msg = { userId: friendId, text: reply, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
                data.dms[friendId].push(msg);
                if (data.activeDm === friendId) appendMessage(msg, true, null, true);
            }, 1500);
        }

        // --- BOT & COMMANDS ---
        function handleCommand(text, server, channel) {
            const parts = text.split(' ');
            const cmd = parts[0];
            const args = parts.slice(1).join(' ');

            if (cmd === '/verify') {
                if (server.bots.length === 0) {
                    const msg = { userId: 'system', text: "No bots in this server to verify you. Create one in Settings!", time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
                    channel.messages.push(msg);
                    appendMessage(msg, true, server);
                    return;
                }

                const bot = server.members.find(m => m.id === server.bots[0].id);
                if (bot) {
                    const replyMsg = { userId: bot.id, text: `Verifying @${data.currentUser.id}... Only you can see this`, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
                    channel.messages.push(replyMsg);
                    appendMessage(replyMsg, true, server);

                    if (!data.dms[bot.id]) data.dms[bot.id] = [];
                    const dmMsg = { userId: bot.id, text: `You have been verified in **${server.name}**.`, time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) };
                    data.dms[bot.id].push(dmMsg);
                    
                    if (!data.currentUser.friends.includes(bot.id)) data.currentUser.friends.push(bot.id);

                    alert(`${bot.name} has sent you a DM regarding verification! Check your DMs.`);
                    renderSidebar();
                }
            }
        }

        // --- PERMISSION & POPUP LOGIC ---
        function hasPermission(userId, permissionKey) {
            const server = data.servers.find(s => s.id === data.activeServer);
            if (!server) return false;
            if (server.owner === userId) return true; 

            const member = server.members.find(m => m.id === userId);
            if (!member || !member.roles) return false;

            return member.roles.some(roleId => {
                const role = server.roles.find(r => r.id === roleId);
                return role && role.permissions && role.permissions[permissionKey];
            });
        }

        function openUserPopup(e, userId) {
            e.stopPropagation();
            const user = findUserById(userId);
            if (!user) return;
            if (user.id === data.currentUser.id) return;

            const popup = document.getElementById('userPopup');
            const rect = e.target.getBoundingClientRect();
            
            const popupHeight = 300; 
            let top = rect.bottom + 10;
            
            if (rect.bottom + popupHeight > window.innerHeight) {
                top = rect.top - popupHeight - 10;
            }

            let left = rect.left + 40;
            if (left + 300 > window.innerWidth) {
                left = rect.left - 300;
            }

            popup.style.top = `${top}px`;
            popup.style.left = `${left}px`;
            popup.style.display = 'block';

            document.getElementById('userPopupAvatar').src = `https://picsum.photos/seed/${user.avatar}/100/100`;
            document.getElementById('userPopupName').innerText = user.name;
            
            const rolesDiv = document.getElementById('userPopupRoles');
            rolesDiv.innerHTML = `<div class="user-popup-section-title">Actions</div>`;

            const modDiv = document.getElementById('modActions');
            modDiv.innerHTML = '';

            const isFriend = data.currentUser.friends.includes(user.id);

            if (!isFriend) {
                const addBtn = document.createElement('button');
                addBtn.className = 'mod-action btn-friend';
                addBtn.innerText = 'Add Friend';
                addBtn.onclick = () => addFriend(user.id);
                modDiv.appendChild(addBtn);
            } else {
                const msgBtn = document.createElement('button');
                msgBtn.className = 'mod-action btn-message';
                msgBtn.innerText = 'Message';
                msgBtn.onclick = () => { closeUserPopup(); openDm(user.id); };
                modDiv.appendChild(msgBtn);
            }

            if (data.viewMode === 'server') {
                const server = data.servers.find(s => s.id === data.activeServer);
                const canBan = hasPermission(data.currentUser.id, 'ban');
                const canKick = hasPermission(data.currentUser.id, 'kick');
                const canManage = (canBan || canKick) && user.id !== data.currentUser.id && user.id !== server.owner && !user.isBot;

                if (canManage) {
                    modDiv.innerHTML += `<div class="user-popup-divider"></div><div class="user-popup-section-title">Moderation</div>`;
                    
                    if (canKick) {
                        const kickBtn = document.createElement('button');
                        kickBtn.className = 'mod-action btn-kick';
                        kickBtn.innerText = 'Kick User';
                        kickBtn.onclick = () => kickUser(user.id);
                        modDiv.appendChild(kickBtn);
                    }
                    if (canBan) {
                        const banBtn = document.createElement('button');
                        banBtn.className = 'mod-action btn-ban';
                        banBtn.innerText = 'Ban User';
                        banBtn.onclick = () => banUser(user.id);
                        modDiv.appendChild(banBtn);
                    }
                }
            }

            setTimeout(() => { document.addEventListener('click', closeUserPopup, { once: true }); }, 10);
        }

        function closeUserPopup() { document.getElementById('userPopup').style.display = 'none'; }

        function addFriend(userId) {
            if (data.currentUser.friends.includes(userId)) {
                alert("You are already friends with this user!");
                closeUserPopup();
                return;
            }

            data.currentUser.friends.push(userId);
            alert("Friend added! Check your DM list.");
            closeUserPopup();
            renderSidebar();
            renderMembers();
        }

        // --- NEW ADD FRIEND BUTTON LOGIC ---
        function promptAddFriend(e) {
            e.stopPropagation(); // Prevent header click
            const name = prompt("Enter a username to add as a friend:");
            if (name) {
                // Create a fake user for the new friend
                const newUser = {
                    id: 'u-' + Date.now(),
                    name: name,
                    tag: "#" + Math.floor(1000 + Math.random() * 9000),
                    avatar: name, // use name as seed for image
                    status: 'online',
                    roles: [],
                    banned: false,
                    isBot: false
                };

                // Add them to the current user's friends list
                data.currentUser.friends.push(newUser.id);

                // Add them to a server so they "exist" in the world
                if (data.servers.length > 0) {
                    data.servers[0].members.push(newUser);
                }

                alert(`Added ${name} to your friends list!`);
                renderSidebar();
                renderMembers();
            }
        }

        function banUser(uid) {
            const server = data.servers.find(s => s.id === data.activeServer);
            const user = server.members.find(m => m.id === uid);
            if (user) {
                user.banned = true;
                user.status = 'offline';
                closeUserPopup();
                renderMembers();
                alert(`${user.name} has been banned.`);
            }
        }

        function kickUser(uid) {
            const server = data.servers.find(s => s.id === data.activeServer);
            const idx = server.members.findIndex(m => m.id === uid);
            if (idx > -1) {
                const name = server.members[idx].name;
                server.members.splice(idx, 1); 
                closeUserPopup();
                renderMembers();
                alert(`${name} has been kicked.`);
            }
        }

